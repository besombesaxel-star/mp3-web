# Copie ce fichier vers .env.local puis renseigne les valeurs necessaires.
# Aucune variable n'est obligatoire: sans backend cloud configure, l'app
# fonctionne en mode local (public/audio, public/cover, data/meta.json).

# --- Supabase (backend cloud recommande) ---------------------------------
# Project URL (Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co
# Meme valeur que SUPABASE_URL, exposee au client (necessaire pour l'auth et le realtime)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Cle service_role (Settings > API) - reste cote serveur uniquement
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Cle publishable/anon (Settings > API) - utilisee cote client pour l'auth
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Bucket de stockage pour les MP3/covers (cree automatiquement au 1er upload)
SUPABASE_STORAGE_BUCKET=media
# Chemin du catalogue partage dans le bucket
SUPABASE_CATALOG_PATH=catalog/tracks.json
# Bucket prive pour les donnees de compte (playlists, favoris, badges...)
SUPABASE_ACCOUNT_BUCKET=account-data

# --- Cloudflare R2 (stockage media : audio/covers/avatars/bannieres) ------
# Recommande une fois le quota Supabase Storage atteint: R2 prend le relai
# pour les mp3/covers/avatars/bannieres (egress gratuit, 10 Go gratuits).
# Supabase reste utilise pour l'auth et les donnees de compte (account-data).
# Account ID Cloudflare (Dashboard > R2 > vue d'ensemble)
R2_ACCOUNT_ID=
# Cle API scopee R2 (Object Read & Write) - Dashboard > R2 > Manage API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Bucket R2 (cree manuellement au prealable, pas d'auto-creation)
R2_BUCKET=media
# Chemin du catalogue partage dans le bucket R2
R2_CATALOG_PATH=catalog/tracks.json
# URL publique du bucket (r2.dev une fois l'acces public active, ou domaine perso)
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev
# Optionnel: override si l'endpoint standard ne convient pas
R2_ENDPOINT=

# --- Notifications push (optionnel) ---------------------------------------
# Genere une paire de cles avec: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Administration (optionnel) --------------------------------------------
# Liste d'IDs utilisateur (UUID Supabase) separes par des virgules ayant acces
# a /admin/badges. Sans cette variable, un ID admin par defaut est utilise.
ADMIN_USER_IDS=

# --- Launcher desktop (optionnel) ------------------------------------------
# Arrete automatiquement le serveur local quand plus aucun client n'est actif
MP3_WEB_AUTO_SHUTDOWN=0

# --- Partage 4G via tunnel (optionnel, scripts/share-4g.mjs) ---------------
PORT=3000
HOST=127.0.0.1
TUNNEL_SUBDOMAIN=
