    "lucide-react": "^0.575.0",
    "next": "^16.2.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "localtunnel": "^2.0.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
