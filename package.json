{
  "name": "mp3-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "share:4g": "node scripts/share-4g.mjs",
    "share:4g:prod": "node scripts/share-4g.mjs --prod",
    "app:launch": "powershell -ExecutionPolicy Bypass -File scripts/launch-app.ps1",
    "app:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-app.ps1",
    "app:package": "powershell -ExecutionPolicy Bypass -File scripts/package-launchers.ps1",
    "firebase:migrate": "node scripts/migrate-library-to-firebase.mjs",
    "supabase:migrate": "node scripts/migrate-library-to-supabase.mjs",
